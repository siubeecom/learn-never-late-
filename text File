<audio id="audioPlayer" src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"></audio>

<!-- 彈窗和遮罩 -->
<div id="overlay"></div>
<div id="popup">
  <div id="popupContent"></div>
  <button onclick="closePopup()">關閉</button>
</div>

<script>
